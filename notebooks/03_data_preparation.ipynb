
import pandas as pd
import numpy as np
from sklearn.preprocessing import MinMaxScaler

# =========================
# CARGA
# =========================
ratings = pd.read_csv("../data/ratings.csv")
interactions = pd.read_csv("../data/interactions.csv")
products = pd.read_csv("../data/products.csv")
users = pd.read_csv("../data/users.csv")

# =========================
# UNIÓN DE DATOS
# =========================
df = interactions.merge(users, on="user_id", how="left")
df = df.merge(products, on="product_id", how="left")

print("Shape final:", df.shape)
display(df.head())

# =========================
# LIMPIEZA BÁSICA
# =========================
df = df.drop_duplicates()

# Completar nulos simples si existen
for col in df.columns:
    if df[col].dtype == "object":
        df[col] = df[col].fillna("desconocido")
    else:
        df[col] = df[col].fillna(df[col].median())

# =========================
# NORMALIZACIÓN MIN-MAX
# =========================
scaler = MinMaxScaler()

numeric_cols = []
for col in ["price", "age", "implicit_score"]:
    if col in df.columns:
        numeric_cols.append(col)

if numeric_cols:
    df[[f"{c}_norm" for c in numeric_cols]] = scaler.fit_transform(df[numeric_cols])

print("Columnas normalizadas:", [f"{c}_norm" for c in numeric_cols])
display(df.head())

# =========================
# GUARDAR DATA PREPARADA
# =========================
df.to_csv("../data/prepared_data.csv", index=False)
print("Archivo guardado: ../data/prepared_data.csv")
